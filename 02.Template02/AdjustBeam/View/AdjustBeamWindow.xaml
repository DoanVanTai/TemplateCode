<Window x:Name="MainWindow" x:Class="DVTools.AdjustBeamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dvt="clr-namespace:DVTools"
        xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
        mc:Ignorable="d"
        
        Title="Adjust Structural Beam" 
        
        BorderBrush="Black"
        BorderThickness="1"
        ResizeMode="NoResize"
        ShowInTaskbar="True" 
        WindowStartupLocation="CenterScreen"
        Height="265" Width="450" 
        Topmost="True" >

    <Window.Resources>
        <ResourceDictionary Source="../../WPF/Resource/Styles.xaml" />
    </Window.Resources>

    <StackPanel >
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0"       
                           Text="Beam -> Wall clearance">
                </TextBlock>
                <TextBlock Grid.Row="1" Grid.Column="0"        
                           Text="Beam -> Pillar clearance">
                </TextBlock>
                <TextBlock Grid.Row="2" Grid.Column="0" 
                           Text="Beam -> Beam inline gap">
                </TextBlock>
                <TextBlock Grid.Row="3" Grid.Column="0" 
                           Text="Beam -> Beam perpendicular">
                </TextBlock>
                <TextBlock Grid.Row="4" Grid.Column="0" 
                           Text="Beam -> conner at pillar">
                </TextBlock>
                <TextBlock Grid.Row="5" Grid.Column="0" 
                           Text="Conner/T-shape at pilllar extend to beam body">
                </TextBlock>
                <TextBlock Grid.Row="6" Grid.Column="0" 
                           Text="Conner at pilllar extend to beam body">
                </TextBlock>
                <TextBox  Grid.Row="0" Grid.Column="1" 
                             Style="{StaticResource TextBoxStyle}"
                            Text="{Binding dataView.beamWall, UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}" >
                </TextBox>

                <TextBox  Grid.Row="1" Grid.Column="1" 
                          Style="{StaticResource TextBoxStyle}"
                          Text="{Binding dataView.beamPillar, UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}">
                </TextBox>
                <TextBox  Grid.Row="2" Grid.Column="1" 
                          Style="{StaticResource TextBoxStyle}"
                          Text="{Binding dataView.beamBeamInline, UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}">
                </TextBox>
                <TextBox  Grid.Row="3" Grid.Column="1" 
                          Style="{StaticResource TextBoxStyle}"
                          Text="{Binding dataView.beamBeamPerpendicular, UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}">
                </TextBox>
              
                <ComboBox Grid.Row="4" Grid.Column="1" TabIndex="3"
                          Style="{StaticResource ComboBoxStyle}" 
                          ItemsSource ="{Binding dataView.allBeamCorner}"
                          SelectedItem ="{Binding dataView.beamCorner, UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}" >
                </ComboBox>
                <CheckBox Grid.Row="5" Grid.Column="1"
                          Style="{StaticResource CheckBoxStyle}" 
                          IsChecked="{Binding dataView.isCornerPillar,UpdateSourceTrigger =PropertyChanged,Mode=TwoWay }" >
                </CheckBox>
                <CheckBox Grid.Row="6" Grid.Column="1"
                          Style="{StaticResource CheckBoxStyle}" 
                          IsChecked="{Binding dataView.isCornerWall,UpdateSourceTrigger =PropertyChanged,Mode=TwoWay }" >
                </CheckBox>
            </Grid>

            <DockPanel LastChildFill="False"  Grid.Row="2" Height="40" >
                <Button DockPanel.Dock="Right"
                        Style="{DynamicResource ButtonStyle}"
                        Content="Adjust"
                        Command="{Binding OKCommand}" 
                        CommandParameter="{Binding ElementName=MainWindow}">
                </Button>
            </DockPanel>
            <Grid Grid.Row="1"  Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition  Height="40"/>
                </Grid.RowDefinitions>
                <ProgressBar Name="ProgressWindow" 
                 Height="30"
                 Style="{DynamicResource ProgressBarStyle}" Margin="0,5,100,0" />
                <TextBlock Grid.ColumnSpan="1"
               Text="{Binding Percent, StringFormat={}{0:0}%}"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" />

            </Grid>
        </Grid>



    </StackPanel>


</Window>
